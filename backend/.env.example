# Smart Expense Analyzer — backend environment variables.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Supabase ---
# Project URL, e.g. https://xyzabc123.supabase.co
SUPABASE_URL=
# Anon (publishable) key — used for sign-up / sign-in flows
SUPABASE_KEY=
# Service-role key — used for server-side admin operations.
# Treat as a secret; do not expose to the frontend.
SUPABASE_SERVICE_KEY=

# --- JWT (legacy HS256 fallback) ---
# Only used when a token's alg is HS256; ES256 tokens are verified via JWKS.
JWT_SECRET=change-me
JWT_ALGORITHM=HS256

# --- Celery / Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Local file storage ---
UPLOAD_DIR=./uploads
