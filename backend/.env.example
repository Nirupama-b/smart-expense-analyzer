# Smart Expense Analyzer — backend environment variables.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Supabase ---
# Project URL, e.g. https://xyzabc123.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co
# Anon (publishable) key — used for sign-up / sign-in flows
SUPABASE_KEY=your_supabase_anon_key_here
# Service-role key — used for server-side admin operations.
# Treat as a secret; do not expose to the frontend.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# --- JWT ---
# HS256 secret (found in Supabase project settings -> API -> JWT Secret)
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256

# --- Celery / Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Local file storage ---
UPLOAD_DIR=./uploads

# --- CORS ---
# Comma-separated list of allowed browser origins.
# Include both 3000 and 3001 — Next.js uses 3001 when 3000 is occupied.
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
