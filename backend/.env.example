# --- Celery / Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Local file storage ---
UPLOAD_DIR=./uploads

# --- CORS ---
# Comma-separated list of allowed browser origins. Wildcards ("*") are
# rejected by browsers when allow_credentials is true, so list each
# explicit origin (no trailing slash).
CORS_ORIGINS=["http://localhost:3000"]
